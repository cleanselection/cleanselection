{
  "name": "cleanselection",
  "version": "1.1.0",
  "description": "Airbrush-style text selection for the web.",
  "license": "MIT",
  "author": {
    "name": "kotoverse",
    "url": "https://github.com/kotoverse"
  },
  "homepage": "https://cleanselection.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cleanselection/cleanselection.git"
  },
  "bugs": {
    "url": "https://github.com/cleanselection/cleanselection/issues"
  },
  "main": "dist/cleanselection.js",
  "browser": "dist/cleanselection.js",
  "unpkg": "dist/cleanselection.min.js",
  "jsdelivr": "dist/cleanselection.min.js",
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "src",
    "types",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "fetch:minifier": "node scripts/fetch-terser.mjs",
    "minify": "node scripts/minify.mjs",
    "docs": "node scripts/generate-function-reference.mjs",
    "test": "node --test tests/*.test.mjs",
    "check": "node scripts/check-release.mjs",
    "package:wordpress": "bash scripts/package-wordpress.sh",
    "prepack": "npm run build && npm run minify && npm test"
  },
  "keywords": [
    "selection",
    "text-selection",
    "airbrush",
    "copy",
    "annotation"
  ],
  "engines": {
    "node": ">=20"
  }
}
